    "claude-code-plugin",
    "session",
    "sessions",
    "session-manager",
    "session-history",
    "resume",
    "session-resume",
    "recap",
    "cli",
    "terminal",
    "iterm2",
    "developer-tools",
    "developer-productivity",
    "agentic-coding",
