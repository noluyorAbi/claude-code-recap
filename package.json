    "bin/",
    "skills/",
    "install.sh",
    "!**/__pycache__",
    "!**/*.pyc"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "claude-code-skill",
    "claude-code-skills",
    "claude-skills",
    "claude-skill",
